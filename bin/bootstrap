#!/usr/bin/env bash
# Bootstrap a fresh VM with the full Fiberco infrastructure
# Usage: bin/bootstrap [--skip-docker] [--skip-claude]
#
# Prerequisites: Ubuntu 24.04 VM with sudo access
# This script is idempotent — safe to re-run.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKIP_DOCKER=false
SKIP_CLAUDE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --skip-docker) SKIP_DOCKER=true; shift ;;
        --skip-claude) SKIP_CLAUDE=true; shift ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

echo "=== Fiberco Infrastructure Bootstrap ==="
echo "Repo root: $REPO_ROOT"
echo ""

# ── 1. System packages ──────────────────────────────────────────────
echo "[1/8] Installing system packages..."
sudo apt-get update -qq
sudo apt-get install -y -qq \
    curl wget git jq tree htop net-tools dnsutils \
    ca-certificates gnupg lsb-release \
    postgresql-client python3 python3-pip python3-venv \
    > /dev/null 2>&1
echo "  Done."

# ── 2. Docker ────────────────────────────────────────────────────────
if [ "$SKIP_DOCKER" = false ]; then
    if ! command -v docker &>/dev/null; then
        echo "[2/8] Installing Docker..."
        curl -fsSL https://get.docker.com | sudo sh
        sudo usermod -aG docker "$USER"
        echo "  Done. You may need to log out and back in for docker group."
    else
        echo "[2/8] Docker already installed."
    fi
else
    echo "[2/8] Skipping Docker install."
fi

# ── 3. Node.js + npm ────────────────────────────────────────────────
if ! command -v node &>/dev/null; then
    echo "[3/8] Installing Node.js 22 LTS..."
    curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - > /dev/null 2>&1
    sudo apt-get install -y -qq nodejs > /dev/null 2>&1
    echo "  Done."
else
    echo "[3/8] Node.js already installed ($(node --version))."
fi

# ── 4. Claude Code ──────────────────────────────────────────────────
if [ "$SKIP_CLAUDE" = false ]; then
    if ! command -v claude &>/dev/null; then
        echo "[4/8] Installing Claude Code..."
        sudo npm install -g @anthropic-ai/claude-code > /dev/null 2>&1
        echo "  Done."
    else
        echo "[4/8] Claude Code already installed."
    fi
else
    echo "[4/8] Skipping Claude Code install."
fi

# ── 5. GitHub CLI ────────────────────────────────────────────────────
if ! command -v gh &>/dev/null; then
    echo "[5/8] Installing GitHub CLI..."
    (type -p wget >/dev/null || (sudo apt update && sudo apt-get install wget -y)) > /dev/null 2>&1
    sudo mkdir -p -m 755 /etc/apt/keyrings
    wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null
    sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | sudo tee /etc/apt/sources.list.d/github-cli-stable.list > /dev/null
    sudo apt-get update -qq && sudo apt-get install -y -qq gh > /dev/null 2>&1
    echo "  Done."
else
    echo "[5/8] GitHub CLI already installed."
fi

# ── 6. Clone basecamp ───────────────────────────────────────────────
if [ ! -d "$REPO_ROOT/basecamp/.git" ]; then
    echo "[6/8] Cloning basecamp..."
    git clone https://github.com/jberry-cloudspace/basecamp-code.git "$REPO_ROOT/basecamp"
    echo "  Done."
else
    echo "[6/8] Basecamp already cloned. Pulling latest..."
    git -C "$REPO_ROOT/basecamp" pull --ff-only
fi

# ── 7. Install CLI tools ────────────────────────────────────────────
echo "[7/8] Installing CLI tools..."

# Add bin/ to PATH if not already there
PROFILE_LINE="export PATH=\"$REPO_ROOT/bin:\$PATH\""
if ! grep -qF "$REPO_ROOT/bin" ~/.bashrc 2>/dev/null; then
    echo "$PROFILE_LINE" >> ~/.bashrc
    echo "  Added $REPO_ROOT/bin to PATH in ~/.bashrc"
fi
export PATH="$REPO_ROOT/bin:$PATH"

# Symlink tracker into /usr/local/bin for Docker containers
if [ -f "$REPO_ROOT/bin/tracker" ]; then
    sudo ln -sf "$REPO_ROOT/bin/tracker" /usr/local/bin/tracker
    echo "  Linked tracker to /usr/local/bin/tracker"
fi

# Make all bin scripts executable
chmod +x "$REPO_ROOT/bin/"*
echo "  Done."

# ── 8. Start infrastructure ─────────────────────────────────────────
echo "[8/8] Starting infrastructure..."

# Create shared network
if ! docker network inspect fiberco-internal &>/dev/null 2>&1; then
    docker network create fiberco-internal
    echo "  Created fiberco-internal network"
fi

# Build base image
echo "  Building base image..."
docker build -t fiberco-base "$REPO_ROOT/docker/base" > /dev/null 2>&1

# Start tracker
echo "  Starting tracker database..."
docker compose -f "$REPO_ROOT/docker/tracker/docker-compose.yml" up -d > /dev/null 2>&1

# Start nginx
echo "  Starting nginx reverse proxy..."
docker compose -f "$REPO_ROOT/docker/nginx/docker-compose.yml" up -d > /dev/null 2>&1

# Start all project containers (generate .env if missing)
for dir in "$REPO_ROOT/docker/projects"/*/; do
    [ -d "$dir" ] || continue
    name=$(basename "$dir")
    [ -f "$dir/docker-compose.yml" ] || continue

    # Generate .env from project name if missing (gitignored)
    if [ ! -f "$dir/.env" ]; then
        cat > "$dir/.env" <<ENVEOF
PROJECT_NAME=$name
ANTHROPIC_API_KEY=
ENVEOF
        echo "  Generated .env for $name"
    fi

    echo "  Starting $name..."
    docker compose -f "$dir/docker-compose.yml" --env-file "$dir/.env" up -d > /dev/null 2>&1
done

echo ""
echo "=== Bootstrap complete ==="
echo ""
echo "Next steps:"
echo "  1. Log out and back in (for docker group membership)"
echo "  2. Run 'source ~/.bashrc' to get bin/ in your PATH"
echo "  3. Run 'gh auth login' to authenticate with GitHub"
echo "  4. Run 'claude' to start Claude Code (will need ANTHROPIC_API_KEY)"
echo "  5. Configure DNS A records in Cloudflare for all project domains"
echo "  6. Run 'bin/renew-certs' to provision SSL certificates"
echo "  7. Run 'tracker board' to verify the tracker is working"
echo "  8. Run 'project list' to verify all containers are running"
echo ""
echo "Repos:"
echo "  Main:     $REPO_ROOT"
echo "  Basecamp: $REPO_ROOT/basecamp"
