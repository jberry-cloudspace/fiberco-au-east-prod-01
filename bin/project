#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PROJECTS_DIR="$REPO_ROOT/docker/projects"
TEMPLATE_DIR="$REPO_ROOT/docker/project-template"
NGINX_DIR="$REPO_ROOT/docker/nginx"
TRACKER_DIR="$REPO_ROOT/docker/tracker"
SHARED_NETWORK="fiberco-internal"

render_template() {
    local template="$1"
    local project_name="$2"
    local project_domain="$3"
    local project_display="$4"
    local project_desc="${5:-New Fiberco project}"

    sed -e "s|{{PROJECT_NAME}}|${project_name}|g" \
        -e "s|{{PROJECT_DOMAIN}}|${project_domain}|g" \
        -e "s|{{PROJECT_DISPLAY_NAME}}|${project_display}|g" \
        -e "s|{{PROJECT_DESCRIPTION}}|${project_desc}|g" \
        "$template"
}

ensure_shared_network() {
    if ! docker network inspect "$SHARED_NETWORK" &>/dev/null; then
        echo "Creating shared internal network '$SHARED_NETWORK'..."
        docker network create "$SHARED_NETWORK"
    fi
}

usage() {
    echo "Usage: project <command> <name> [options]"
    echo ""
    echo "Commands:"
    echo "  create <name> [--domain d] [--description d]"
    echo "                                Create a new project with CLAUDE.md + nginx"
    echo "  up <name>                     Start a project"
    echo "  down <name>                   Stop a project"
    echo "  shell <name>                  Open a shell in the app container"
    echo "  db <name>                     Open psql in the db container"
    echo "  logs <name>                   Tail logs for a project"
    echo "  list                          List all projects"
    echo "  destroy <name>                Stop and remove a project (keeps volumes)"
    echo "  destroy <name> --volumes      Stop and remove a project AND its data"
    echo "  nginx-up                      Start the nginx reverse proxy"
    echo "  nginx-down                    Stop the nginx reverse proxy"
    echo "  nginx-reload                  Reload nginx config (after adding routes)"
    echo "  tracker-up                    Start the tracker database"
    echo "  tracker-down                  Stop the tracker database"
    echo "  start-all                     Start nginx, tracker, and all projects"
    echo "  stop-all                      Stop everything"
    exit 1
}

project_dir() {
    echo "$PROJECTS_DIR/$1"
}

compose() {
    local name="$1"; shift
    docker compose -f "$(project_dir "$name")/docker-compose.yml" --env-file "$(project_dir "$name")/.env" "$@"
}

nginx_compose() {
    docker compose -f "$NGINX_DIR/docker-compose.yml" "$@"
}

cmd_create() {
    local name="$1"; shift
    local domain=""
    local description=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --domain) domain="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    local dir="$PROJECTS_DIR/$name"
    if [[ -d "$dir" ]]; then
        echo "Error: Project '$name' already exists at $dir"
        exit 1
    fi

    # Derive defaults
    local short_name="${name#fiberco-}"
    domain="${domain:-${short_name}.fiberco.com.au}"
    description="${description:-New Fiberco project}"
    local display_name="Fiberco ${short_name^}"

    echo "Creating project '$name'..."
    mkdir -p "$dir"
    cp "$TEMPLATE_DIR/docker-compose.yml" "$dir/docker-compose.yml"

    cat > "$dir/.env" <<EOF
PROJECT_NAME=$name
ANTHROPIC_API_KEY=
EOF

    # Generate CLAUDE.md from template
    if [[ -f "$TEMPLATE_DIR/CLAUDE.md.template" ]]; then
        render_template "$TEMPLATE_DIR/CLAUDE.md.template" "$name" "$domain" "$display_name" "$description" > "$dir/CLAUDE.md"
        echo "  Generated CLAUDE.md with basecamp integration"
    fi

    # Generate nginx config from template
    if [[ -f "$TEMPLATE_DIR/nginx.conf.template" ]]; then
        local nginx_conf="$NGINX_DIR/conf.d/${name}.conf"
        render_template "$TEMPLATE_DIR/nginx.conf.template" "$name" "$domain" "$display_name" "$description" > "$nginx_conf"
        echo "  Generated nginx config at docker/nginx/conf.d/${name}.conf"
    fi

    ensure_shared_network

    echo "Building and starting containers..."
    compose "$name" up -d --build

    echo ""
    echo "Project '$name' is running!"
    echo "  App container: ${name}-app"
    echo "  DB container:  ${name}-db (postgres)"
    echo "  Domain:        ${domain}"
    echo ""
    echo "  Shell:  project shell $name"
    echo "  DB:     project db $name"
    echo "  Logs:   project logs $name"
    echo ""
    echo "Remaining setup:"
    echo "  1. Set API key:       edit docker/projects/$name/.env"
    echo "  2. Add DNS:           Cloudflare A record for ${domain}"
    echo "  3. Provision SSL:     bin/renew-certs"
    echo "  4. Reload nginx:      project nginx-reload"
    echo "  5. Register tracker:  tracker create \"Initial setup\" --project $name --type change"
    echo "  6. Update CLAUDE.md:  add project to root CLAUDE.md projects table"
    echo ""
    echo "See playbooks/new-project-setup/PLAYBOOK.md for the full checklist."
}

cmd_up() {
    ensure_shared_network
    compose "$1" up -d
    echo "Project '$1' started."
}

cmd_down() {
    compose "$1" down
    echo "Project '$1' stopped."
}

cmd_shell() {
    docker exec -it "${1}-app" bash
}

cmd_db() {
    docker exec -it "${1}-db" psql -U app -d "$1"
}

cmd_logs() {
    compose "$1" logs -f
}

cmd_list() {
    echo "Projects:"
    if [[ -d "$PROJECTS_DIR" ]]; then
        for dir in "$PROJECTS_DIR"/*/; do
            [[ -d "$dir" ]] || continue
            local name
            name=$(basename "$dir")
            local status
            if docker ps --format '{{.Names}}' | grep -q "^${name}-app$"; then
                status="running"
            else
                status="stopped"
            fi
            echo "  $name  [$status]"
        done
    else
        echo "  (none)"
    fi
}

cmd_destroy() {
    local name="$1"; shift
    local volumes=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --volumes) volumes="-v"; shift ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    compose "$name" down $volumes
    rm -rf "$(project_dir "$name")"
    echo "Project '$name' destroyed."
}

cmd_nginx_up() {
    ensure_shared_network
    nginx_compose up -d
    echo "Nginx reverse proxy started on ports 80/443."
}

cmd_nginx_down() {
    nginx_compose down
    echo "Nginx reverse proxy stopped."
}

cmd_nginx_reload() {
    docker exec fiberco-nginx nginx -s reload
    echo "Nginx config reloaded."
}

tracker_compose() {
    docker compose -f "$TRACKER_DIR/docker-compose.yml" "$@"
}

cmd_tracker_up() {
    ensure_shared_network
    tracker_compose up -d
    echo "Tracker database started."
}

cmd_tracker_down() {
    tracker_compose down
    echo "Tracker database stopped."
}

cmd_start_all() {
    ensure_shared_network
    echo "Starting tracker..."
    tracker_compose up -d
    echo "Starting nginx..."
    nginx_compose up -d
    echo "Starting projects..."
    if [[ -d "$PROJECTS_DIR" ]]; then
        for dir in "$PROJECTS_DIR"/*/; do
            [[ -d "$dir" ]] || continue
            local name
            name=$(basename "$dir")
            echo "  Starting $name..."
            compose "$name" up -d
        done
    fi
    echo "All services started."
}

cmd_stop_all() {
    echo "Stopping projects..."
    if [[ -d "$PROJECTS_DIR" ]]; then
        for dir in "$PROJECTS_DIR"/*/; do
            [[ -d "$dir" ]] || continue
            local name
            name=$(basename "$dir")
            echo "  Stopping $name..."
            compose "$name" down
        done
    fi
    echo "Stopping nginx..."
    nginx_compose down
    echo "Stopping tracker..."
    tracker_compose down
    echo "All services stopped."
}

[[ $# -lt 1 ]] && usage

cmd="$1"; shift

case "$cmd" in
    create)       [[ $# -lt 1 ]] && usage; cmd_create "$@" ;;
    up)           [[ $# -lt 1 ]] && usage; cmd_up "$1" ;;
    down)         [[ $# -lt 1 ]] && usage; cmd_down "$1" ;;
    shell)        [[ $# -lt 1 ]] && usage; cmd_shell "$1" ;;
    db)           [[ $# -lt 1 ]] && usage; cmd_db "$1" ;;
    logs)         [[ $# -lt 1 ]] && usage; cmd_logs "$1" ;;
    list)         cmd_list ;;
    destroy)      [[ $# -lt 1 ]] && usage; cmd_destroy "$@" ;;
    nginx-up)     cmd_nginx_up ;;
    nginx-down)   cmd_nginx_down ;;
    nginx-reload) cmd_nginx_reload ;;
    tracker-up)   cmd_tracker_up ;;
    tracker-down) cmd_tracker_down ;;
    start-all)    cmd_start_all ;;
    stop-all)     cmd_stop_all ;;
    *)            usage ;;
esac
