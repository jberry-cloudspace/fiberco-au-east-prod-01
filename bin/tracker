#!/usr/bin/env bash
# Fiberco wrapper — sets instance-specific env vars then delegates to basecamp tracker
export TRACKER_DB_HOST="${TRACKER_DB_HOST:-fiberco-tracker-db}"
export SHARED_NETWORK="${SHARED_NETWORK:-fiberco-internal}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$SCRIPT_DIR/../basecamp/expansions/tracker/bin/tracker" "$@"
