#!/usr/bin/env bash
# Inside containers, TRACKER_DB_HOST is set via Dockerfile ENV
# This is a copy of the basecamp tracker for use inside Docker containers
# Source of truth: basecamp/expansions/tracker/bin/tracker

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# If basecamp tracker exists (host mount), use it; otherwise fall back to this copy
if [[ -x "/home/app/basecamp/expansions/tracker/bin/tracker" ]]; then
    exec /home/app/basecamp/expansions/tracker/bin/tracker "$@"
else
    # Fallback: the tracker is embedded in the container image
    exec "$SCRIPT_DIR/../../basecamp/expansions/tracker/bin/tracker" "$@" 2>/dev/null || \
    exec /usr/local/bin/tracker-embedded "$@" 2>/dev/null || {
        echo "Error: tracker not found. Ensure basecamp is available."
        exit 1
    }
fi
